@startuml

left to right direction

class Шрек {
  - String имя
  - int уровеньСилы
  - bool являетсяОгром
  + сражаться()
  + вестиПереговоры()
  + спасать()
  + заключитьСделку()
}

class Фиона {
  - String имя
  - bool являетсяОгром
  - String человеческаяФорма
  - String формаОгра
  + трансформироваться()
  + сопротивляться()
  + ждатьСпасения()
  + {static} void проверитьВремяСуток()
}

class Дракон {
  - String имя
  - String локация
  - int сила
  - bool враждебен
  + охранятьБашню()
  + атаковать()
  + бытьПобежденным()
  + спать()
}

class ЛордФаркуад {
  - String имя
  - String титул
  - int уровеньВласти
  + нанять()
  + предложитьСделку()
  + наградить()
}

class ЗаключитьСделку {
  - String текстКонтракта
  - Date датаПодписания
  - bool выполнено
  + подписать()
  + вестиПереговоры()
  + выполнить()
}

class СражениеСДраконом {
  - String локация
  - int сложность
  - String исходБитвы
  + начать()
  + выполнить()
  + завершить()
}

class ПобедаНадДраконом {
  - String захваченныйОбъект
  + объявитьПобеду()
  + извлечьПринцессу()
}

class СпасениеПринцессы {
  - String местоСпасения
  - DateTime времяСпасения
  - bool успешно
  + извлечь()
  + транспортировать()
  + доставить()
}

class ПринцессаСопротивляется {
  - String типСопротивления
  - int уровеньСопротивления
  + проявитьСопротивление()
  + создатьПрепятствие()
}

class ЗахватПринцессы {
  - String типРешения
  - bool являетсяПохищением
  + сделатьВыбор()
  + захватить()
  + обезвредить()
}

' === State для Фионы (день/ночь) ===
class СостояниеЧеловек {
  + действовать()
  + трансформироватьсяВОгра()
}

class СостояниеОгр {
  + действовать()
  + трансформироватьсяВЧеловека()
}

class ПередачаФионы {
  - String способПередачи
  - DateTime времяПередачи
  + передать()
  + получить()
  + подтвердить()
}

class УходОтДракона {
  - String маршрутПобега
  - int скорость
  + бежать()
  + спрятаться()
  + транспортировать()
}

Шрек --> ЗаключитьСделку : участвует в
ЛордФаркуад --> ЗаключитьСделку : инициирует

Шрек --> СражениеСДраконом : участвует в
Дракон --> СражениеСДраконом : является антагонистом

Шрек --> ПобедаНадДраконом : достигает
Шрек --> СпасениеПринцессы : выполняет


Фиона --> ПринцессаСопротивляется : создает

СражениеСДраконом ..> ПобедаНадДраконом : <<включает>>
ПобедаНадДраконом ..> СпасениеПринцессы : <<включает>>
ЗахватПринцессы <.. ПринцессаСопротивляется : <<расширяет>>

Фиона *-- СостояниеЧеловек : дневное состояние
Фиона *-- СостояниеОгр : ночное состояние

ПобедаНадДраконом --> ПередачаФионы : запускает
ПередачаФионы --> Фиона : передает
ПередачаФионы --> Шрек : кому

СражениеСДраконом --> УходОтДракона : следует за

УходОтДракона --> СпасениеПринцессы : завершает

note top of Фиона
  **State-паттерн:**
  - День (День): СостояниеЧеловек (являетсяОгром = false)
  - Ночь (Ночь): СостояниеОгр (являетсяОгром = true)
  Трансформация происходит автоматически
end note

note bottom of ПередачаФионы
  Реализует sequence-диаграмму:
  "Передача Фионы от Дракона к Шреку"
end note

note right of УходОтДракона
  Соответствует Activity:
  Сражение -> Уход от дракона
end note

@enduml
